  file-print "region,WEI_real,prod_baseline,prod_wei_plus01,prod_wei_plus02,prod_wei_plus03"
  file-close

  let regions (list
    "Piemonte" "Valle d'Aosta" "Lombardia" "Trentino Alto Adige"
    "Veneto" "Friuli-Venezia Giulia" "Liguria" "Emilia-Romagna"
    "Toscana" "Umbria" "Marche" "Lazio" "Abruzzo" "Molise"
    "Campania" "Puglia" "Basilicata" "Calabria" "Sicilia" "Sardegna"
  )

  let n-runs 100

  foreach regions [ r ->
    set country-select r
    print (word "Processing: " r)
    load-region-data
    let real-WEI WEI-value

    let sum-b  0
    let sum-p1 0
    let sum-p2 0
    let sum-p3 0

    repeat n-runs [
      setup-counterfactual -1 -1
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-b sum-b + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.1)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p1 sum-p1 + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.2)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p2 sum-p2 + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.3)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p3 sum-p3 + (real-gdp / (n-employed * 8)) ]
    ]

    file-open filename
    file-print (word r "," precision real-WEI 4 ","
      precision (sum-b  / n-runs) 4 ","
      precision (sum-p1 / n-runs) 4 ","
      precision (sum-p2 / n-runs) 4 ","
      precision (sum-p3 / n-runs) 4)
    file-close
    print (word "  WEI=" precision real-WEI 3
      "  base=" precision (sum-b / n-runs) 4
      "  +0.1=" precision (sum-p1 / n-runs) 4
      "  +0.2=" precision (sum-p2 / n-runs) 4
      "  +0.3=" precision (sum-p3 / n-runs) 4)
  ]
  print "=== WEI TARGETING IT COMPLETE ==="
end


