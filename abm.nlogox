<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; CULTURE AND MACROECONOMIC PERFORMANCE
;; Agent-Based Model -- Cannata & Biondo (2026)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

extensions [csv]

;;--------------------------------------------------------------------
;; AGENT TYPES
;;--------------------------------------------------------------------
breed [firms  firm]    ;; firms (index h)
breed [workers worker] ;; workers (index i)

;;--------------------------------------------------------------------
;; GLOBAL VARIABLES
;;--------------------------------------------------------------------
globals [

  ;; --- Normalizations ---
  wage              ;; \bar{w}: wage rate (normalized to 1)
  price-capital     ;; \bar{p}_K: capital price (normalized to 1)
  A-param           ;; A: total factor productivity, calibrated in (1, 3)
  num-ideal-workers ;; d: size of the type space

  ;; --- Economy size ---
  N-workers         ;; N_w: total number of workers
  N-firms           ;; N_f: total number of firms

  ;; --- Expected demand ---
  E-sales-base      ;; \bar{E}: mean expected sales, calibrated from empirical employment rate

  ;; --- National accounting ---
  GDP               ;; nominal GDP
  price-index       ;; aggregate price deflator
  unemployment-rate ;; simulated unemployment rate
  total-inventories ;; aggregate unsold inventories
  u-rate            ;; empirical unemployment rate (from CSV)

  ;; --- Culture ---
  WEI-value         ;; Work Ethic Index for the current country/region

  ;; --- Switches ---
  baseline-mode?    ;; if TRUE, effective-hours = 1 for all workers (no mismatch)

  ;; --- Factor pools ---
  available-workers ;; agentset of unemployed workers available for hiring
  available-capital ;; remaining capital units in the aggregate pool
]

;;--------------------------------------------------------------------
;; FIRM VARIABLES
;;--------------------------------------------------------------------
;; Each firm h operates a Leontief technology with fixed coefficients
;; (a-L, a-K). Production unfolds in two phases:
;;   Phase 1 (allocation): firm computes desired inputs, scales down
;;                         if factors are scarce, hires and purchases.
;;   Phase 2 (production): firm produces via Leontief, accounting for
;;                         effective labour (mismatch + culture).
;;--------------------------------------------------------------------
firms-own [

  ;; --- Technology ---
  ideal-type      ;; n_{h,D}: firm's ideal worker type, integer in {1,...,d}
  a-L             ;; a_L^h: Leontief labour coefficient ~ N(0.55, 0.05), > 0
  a-K             ;; a_K^h: Leontief capital coefficient ~ N(0.40, 0.05), > 0

  ;; --- Phase 1: planning ---
  expected-sales  ;; E[q_h]: expected sales, calibrated to match empirical employment
  desired-labor   ;; L_h^* = a_L * E[q_h]: planned labour demand
  desired-capital ;; K_h^* = a_K * E[q_h]: planned capital demand

  ;; --- Phase 1: realized inputs ---
  actual-labor    ;; L_h: workers actually hired
  actual-capital  ;; K_h: capital actually purchased from the pool

  ;; --- Phase 2: production ---
  actual-output   ;; y_h = A * min(K_h/a_K, L_h^{eff}/a_L)
  inventories     ;; INV_h = max(0, y_h - scaled-sales)
  scaled-sales    ;; post-scaling expected sales (used for inventory accounting)

  ;; --- Costs and prices ---
  total-cost      ;; TC_h = w * L_h + p_K * K_h
  price           ;; p_h = TC_h / y_h  (set ex post in produce)

  ;; --- Matching ---
  my-workers      ;; agentset of workers hired by this firm
]

;;--------------------------------------------------------------------
;; WORKER VARIABLES
;;--------------------------------------------------------------------
;; Each worker i has a skill profile (worker-profile) and a cultural
;; coefficient (beta). Effective hours depend on the distance between
;; the worker's profile and the firm's ideal type, modulated by beta:
;;   h_{eff} = 1 - (1 - beta_i) * eta,  eta = |profile - ideal| / d
;;--------------------------------------------------------------------
workers-own [

  ;; --- Profile and culture ---
  worker-profile  ;; n_{i,S}: worker's skill profile, real in [0, d]
  beta            ;; beta_i: cultural coefficient in [0, 1]
                  ;;   beta = 1: culture fully offsets mismatch penalty
                  ;;   beta = 0: no cultural buffer (h_eff = 1 - eta)

  ;; --- Employment status ---
  employed?       ;; TRUE if hired in the current period
  my-firm         ;; reference to the employing firm (nobody if unemployed)

  ;; --- Labour intensity ---
  effective-hours ;; h_{ih}^{eff}: fraction of effective hours worked
]

;;--------------------------------------------------------------------
;; SETUP
;;--------------------------------------------------------------------
;; Initializes the economy: loads country/region parameters from CSV,
;; creates firms and workers, and calibrates expected sales so that
;; aggregate labour demand is consistent with the empirical employment rate.
;;--------------------------------------------------------------------
to setup
  clear-all
  set baseline-mode? false

  ifelse use-italy? [ load-region-data ] [ load-country-data ]

  set wage 1
  set price-capital 1
  set num-ideal-workers 100
  set available-capital 0
  set GDP 0
  set price-index 0
  set unemployment-rate 0
  set total-inventories 0

  ;; --- Create firms ---
  create-firms N-firms [
    set a-L random-positive-normal 0.55 0.05
    set a-K random-positive-normal 0.40 0.05
    assign-ideal-type
    set desired-labor 0
    set desired-capital 0
    set actual-labor 0
    set actual-capital 0
    set actual-output 0
    set total-cost 0
    set price 0
    set inventories 0
    set scaled-sales 0
    set my-workers no-turtles
  ]

  ;; --- Calibrate expected sales ---
  ;; E-sales-base = N_w * (1 - u/100) / (N_f * mean(a_L))
  let mean-aL mean [a-L] of firms
  set E-sales-base (N-workers * (1 - u-rate / 100)) / (N-firms * mean-aL)

  ask firms [
    set expected-sales random-positive-normal E-sales-base (E-sales-base * 0.1)
  ]
  let sample-mean mean [expected-sales] of firms
  if sample-mean > 0 [
    ask firms [ set expected-sales expected-sales * (E-sales-base / sample-mean) ]
  ]

  ;; --- Create workers ---
  ;; beta ~ N(WEI-value, 0.05) clipped to [0,1] if use-WEI? is TRUE; 0 otherwise.
  create-workers N-workers [
    assign-worker-profile
    set beta (ifelse-value use-WEI?
               [ clip-01 (random-normal WEI-value 0.05) ]
               [ 0 ])
    set employed? false
    set my-firm nobody
    set effective-hours 0
  ]

  ;; --- Initialize factor pools ---
  set available-workers workers
  set available-capital sum [a-K * expected-sales] of firms

  reset-ticks
end

;;--------------------------------------------------------------------
;; HELPER PROCEDURES
;;--------------------------------------------------------------------

;; Truncated normal: redraws until strictly positive.
to-report random-positive-normal [mu sigma]
  let x random-normal mu sigma
  while [x <= 0] [ set x random-normal mu sigma ]
  report x
end

;; Clips x to [0, 1].
to-report clip-01 [x]
  if x < 0 [ report 0 ]
  if x > 1 [ report 1 ]
  report x
end

;;--------------------------------------------------------------------
;; TYPE AND PROFILE ASSIGNMENT
;;--------------------------------------------------------------------
;; Three scenarios govern the distribution of firm ideal types and
;; worker profiles in the type space {1,...,d} x [0,d]:
;;
;;   uniform:      deterministic, evenly spaced across [1,d].
;;   concentrated: 75% of firms near type 90; 75% of workers near 10.
;;   random:       uniform random draws (used for empirical calibration).
;;--------------------------------------------------------------------

to assign-ideal-type
  if scenario = "uniform" [
    let firm-index position self sort firms
    set ideal-type (firm-index mod num-ideal-workers) + 1
  ]
  if scenario = "concentrated" [
    ifelse random-float 1 < 0.75
      [ set ideal-type max (list 1 (min (list num-ideal-workers
          (round random-positive-normal 90 0.1)))) ]
      [ set ideal-type 1 + random num-ideal-workers ]
  ]
  if scenario = "random" [
    set ideal-type 1 + random num-ideal-workers
  ]
end

to assign-worker-profile
  ;; Uniform: offset by 0.5 to avoid exact coincidence with integer ideal types.
  if scenario = "uniform" [
    let worker-index position self sort workers
    set worker-profile (worker-index mod num-ideal-workers) + 0.5
  ]
  if scenario = "concentrated" [
    ifelse random-float 1 < 0.75
      [ set worker-profile max (list 0 (min (list num-ideal-workers
          (random-positive-normal 10 0.1)))) ]
      [ set worker-profile random-float num-ideal-workers ]
  ]
  if scenario = "random" [
    set worker-profile random-float num-ideal-workers
  ]
end

;;--------------------------------------------------------------------
;; GO
;;--------------------------------------------------------------------
;; Executes one static period. Sequence:
;;   1. calculate-and-acquire-inputs
;;   2. produce
;;   3. national-accounting
;;--------------------------------------------------------------------
to go

  ask workers [
    set employed? false
    set my-firm nobody
    set effective-hours 0
  ]
  ask firms [
    set my-workers no-turtles
    set actual-labor 0
    set actual-capital 0
    set actual-output 0
    set total-cost 0
    set price 0
    set inventories 0
  ]

  set available-workers workers
  set available-capital sum [a-K * expected-sales] of firms

  calculate-and-acquire-inputs
  produce
  national-accounting

  tick
end

;;--------------------------------------------------------------------
;; PHASE 1: INPUT ALLOCATION
;;--------------------------------------------------------------------
;; Firms activated in random order. Each firm computes desired inputs,
;; scales down if factors are scarce, hires workers and purchases capital.
;;--------------------------------------------------------------------
to calculate-and-acquire-inputs

  let firm-order shuffle sort firms

  foreach firm-order [ f ->
    ask f [

      let target-sales expected-sales
      let done? false

      while [not done?] [

        let labor-needed a-L * target-sales
        let capital-needed a-K * target-sales
        let labor-available count available-workers
        let capital-available-now available-capital

        if labor-available = 0 or capital-available-now <= 0 [
          set desired-labor 0
          set desired-capital 0
          set done? true
        ]

        if not done? [
          let n-workers-needed ceiling labor-needed

          ifelse n-workers-needed <= labor-available and
                 capital-needed <= capital-available-now [

            ;; Case 1: both factors sufficient
            set desired-labor n-workers-needed
            set target-sales desired-labor / a-L
            set desired-capital a-K * target-sales
            set done? true

          ] [

            ;; Case 2: at least one factor scarce — scale down
            let scale-labor   ifelse-value (n-workers-needed > 0)
              [labor-available / n-workers-needed] [1]
            let scale-capital  ifelse-value (capital-needed > 0)
              [capital-available-now / capital-needed] [1]
            let scale-factor  min (list scale-labor scale-capital)

            set target-sales target-sales * scale-factor

            let new-labor ceiling (a-L * target-sales)
            ifelse new-labor >= 1 and
                   new-labor <= labor-available and
                   (a-K * target-sales) <= capital-available-now [
              set desired-labor new-labor
              set target-sales desired-labor / a-L
              set desired-capital a-K * target-sales
              set done? true
            ] [
              ;; Fallback: take whatever is available
              set desired-labor min (list labor-available (max (list 1 new-labor)))
              set target-sales desired-labor / a-L
              set desired-capital min (list capital-available-now
                                           (a-K * target-sales))
              set done? true
            ]
          ]
        ]
      ]

      ;; --- Hire workers (random selection; mismatch manifests in production) ---
      let n-to-hire min (list desired-labor count available-workers)
      if n-to-hire = 0 and count available-workers > 0 [ set n-to-hire 1 ]

      set my-workers n-of n-to-hire available-workers
      ask my-workers [ set employed? true  set my-firm myself ]
      set available-workers available-workers with [not employed?]
      set actual-labor count my-workers

      ;; --- Purchase capital ---
      set actual-capital desired-capital
      set available-capital available-capital - actual-capital

      ;; --- Total cost: TC_h = w * L_h + p_K * K_h ---
      set total-cost wage * actual-labor + price-capital * actual-capital
      set scaled-sales target-sales
    ]
  ]
end

;;--------------------------------------------------------------------
;; PHASE 2: PRODUCTION
;;--------------------------------------------------------------------
;; Leontief production with cultural mismatch. Price set ex post.
;;--------------------------------------------------------------------
to produce
  ask firms [

    if actual-labor = 0 [
      set actual-output 0
      set inventories 0
    ]

    if actual-labor > 0 [

      ;; Effective hours: h_{eff} = 1 - (1 - beta_i) * eta
      ;; eta = |worker-profile - ideal-type| / d
      ask my-workers [
        ifelse baseline-mode? [
          set effective-hours 1
        ] [
          let eta abs (worker-profile - [ideal-type] of myself) / num-ideal-workers
          set effective-hours clip-01 (1 - (1 - beta) * eta)
        ]
      ]

      let effective-labor sum [effective-hours] of my-workers

      ;; Leontief: y_h = A * min(K_h / a_K, L_h^{eff} / a_L)
      let output-from-capital actual-capital / a-K
      let output-from-labor   effective-labor / a-L
      set actual-output A-param * min (list output-from-capital output-from-labor)

      let sold min (list actual-output scaled-sales)
      set inventories actual-output - sold
      if actual-output > 0 [ set price total-cost / actual-output ]
    ]
  ]
end

;;--------------------------------------------------------------------
;; PHASE 3: NATIONAL ACCOUNTING
;;--------------------------------------------------------------------
to national-accounting

  set GDP sum [price * actual-output] of firms

  let total-output sum [actual-output] of firms
  ifelse total-output > 0 [
    set price-index sum [price * (actual-output / total-output)] of firms
  ] [
    set price-index 0
  ]

  let unemployed count workers with [not employed?]
  ifelse count workers > 0 [
    set unemployment-rate (unemployed / count workers) * 100
  ] [
    set unemployment-rate 0
  ]

  set total-inventories sum [inventories] of firms

  let real-GDP ifelse-value (price-index > 0) [GDP / price-index] [0]
  let total-effective-hours sum [effective-hours * 8] of workers with [employed?]
  let productivity-per-hour ifelse-value (total-effective-hours > 0)
    [real-GDP / total-effective-hours] [0]

  print "=== NATIONAL ACCOUNTING ==="
  print (word "Nominal GDP:        " precision GDP 3)
  print (word "Price index:        " precision price-index 4)
  print (word "Real GDP:           " precision real-GDP 3)
  print (word "Unemployment rate:  " precision unemployment-rate 2 "%")
  print (word "Total inventories:  " precision total-inventories 3)
  print (word "Productivity/hour:  " precision productivity-per-hour 4)
end

;;--------------------------------------------------------------------
;; CSV PARSER
;;--------------------------------------------------------------------
to-report split-csv [line]
  let result []
  let current ""
  let i 0
  while [i < length line] [
    ifelse item i line = "," [
      set result lput current result
      set current ""
    ] [
      set current (word current item i line)
    ]
    set i i + 1
  ]
  report lput current result
end

;;--------------------------------------------------------------------
;; CSV LOADERS
;;--------------------------------------------------------------------
;; CSV structure (columns 0-6):
;;   name | N-workers | N-firms | A-param | E-sales (unused) | WEI | u-rate

to load-country-data
  file-open "data_europe1.csv"
  let header file-read-line
  while [not file-at-end?] [
    let fields split-csv file-read-line
    if item 0 fields = country-select [
      set N-workers read-from-string (item 1 fields)
      set N-firms   read-from-string (item 2 fields)
      set A-param   read-from-string (item 3 fields)
      set WEI-value read-from-string (item 5 fields)
      set u-rate    read-from-string (item 6 fields)
      file-close
      stop
    ]
  ]
  file-close
  user-message (word "Country not found in CSV: " country-select)
end

to load-region-data
  file-open "data_italy.csv"
  let header file-read-line
  while [not file-at-end?] [
    let fields split-csv file-read-line
    if item 0 fields = country-select [
      set N-workers read-from-string (item 1 fields)
      set N-firms   read-from-string (item 2 fields)
      set A-param   read-from-string (item 3 fields)
      set WEI-value read-from-string (item 5 fields)
      set u-rate    read-from-string (item 6 fields)
      file-close
      stop
    ]
  ]
  file-close
  user-message (word "Region not found in CSV: " country-select)
end

;;--------------------------------------------------------------------
;; SAMPLE MEAN REPORTERS
;;--------------------------------------------------------------------
;; Returns [mean-A mean-WEI] across all rows of the CSV.

to-report compute-eu-means
  file-open "data_europe1.csv"
  let header file-read-line
  let sum-A 0   let sum-WEI 0   let n 0
  while [not file-at-end?] [
    let fields split-csv file-read-line
    if length fields >= 7 [
      set sum-A   sum-A   + read-from-string (item 3 fields)
      set sum-WEI sum-WEI + read-from-string (item 5 fields)
      set n n + 1
    ]
  ]
  file-close
  print (word "EU means: A=" precision (sum-A / n) 4
              "  WEI=" precision (sum-WEI / n) 4
              "  N=" n)
  report (list (sum-A / n) (sum-WEI / n))
end

to-report compute-it-means
  file-open "data_italy.csv"
  let header file-read-line
  let sum-A 0   let sum-WEI 0   let n 0
  while [not file-at-end?] [
    let fields split-csv file-read-line
    if length fields >= 7 [
      set sum-A   sum-A   + read-from-string (item 3 fields)
      set sum-WEI sum-WEI + read-from-string (item 5 fields)
      set n n + 1
    ]
  ]
  file-close
  print (word "IT means: A=" precision (sum-A / n) 4
              "  WEI=" precision (sum-WEI / n) 4
              "  N=" n)
  report (list (sum-A / n) (sum-WEI / n))
end

;;--------------------------------------------------------------------
;; RESULT EXPORT
;;--------------------------------------------------------------------
to export-results [filename run-number]
  let real-GDP ifelse-value (price-index > 0) [GDP / price-index] [0]
  let n-employed count workers with [employed?]
  let total-effective-hours sum [effective-hours * 8] of workers with [employed?]
  let prod-w ifelse-value (n-employed > 0)
    [real-GDP / (n-employed * 8)] [0]
  let prod-e ifelse-value (total-effective-hours > 0)
    [real-GDP / total-effective-hours] [0]

  if not file-exists? filename [
    file-open filename
    file-print (word
      "run,country,scenario,"
      "nominal_GDP,price_index,real_GDP,"
      "unemployment_rate,total_inventories,"
      "prod_per_worker_hour,prod_per_effective_hour,"
      "employed,Nw,Nf,A,WEI,"
      "E_sales_base,E_sales_mean,u_target")
    file-close
  ]

  file-open filename
  file-print (word
    run-number "," country-select "," scenario ","
    precision GDP 6 "," precision price-index 6 ","
    precision real-GDP 6 "," precision unemployment-rate 4 ","
    precision total-inventories 6 ","
    precision prod-w 6 "," precision prod-e 6 ","
    n-employed "," N-workers "," N-firms ","
    precision A-param 6 "," precision WEI-value 7 ","
    precision E-sales-base 6 ","
    precision mean [expected-sales] of firms 6 ","
    u-rate)
  file-close
end

;;--------------------------------------------------------------------
;; BENCHMARK SETUP (fixed parameters)
;;--------------------------------------------------------------------
;; N_w = 4300, N_f = 700, A = 1.8, WEI = 0.5, u = 5%.
;; Used by the stability analysis and the theoretical experiment.

to setup-benchmark-prof
  clear-all
  set baseline-mode? false
  set N-workers 4300
  set N-firms   700
  set wage 1   set price-capital 1   set num-ideal-workers 100
  if A-param   = 0 [ set A-param   1.8 ]
  if WEI-value = 0 [ set WEI-value 0.5 ]
  if u-rate    = 0 [ set u-rate    5   ]
  set available-capital 0   set GDP 0
  set price-index 0   set unemployment-rate 0   set total-inventories 0

  create-firms N-firms [
    set a-L random-positive-normal 0.55 0.05
    set a-K random-positive-normal 0.40 0.05
    assign-ideal-type
    set desired-labor 0   set desired-capital 0
    set actual-labor 0    set actual-capital 0
    set actual-output 0   set total-cost 0
    set price 0           set inventories 0
    set scaled-sales 0    set my-workers no-turtles
  ]

  let mean-aL mean [a-L] of firms
  set E-sales-base (N-workers * (1 - u-rate / 100)) / (N-firms * mean-aL)
  ask firms [
    set expected-sales random-positive-normal E-sales-base (0.1 * E-sales-base)
  ]
  let sample-mean mean [expected-sales] of firms
  if sample-mean > 0 [
    ask firms [ set expected-sales expected-sales * (E-sales-base / sample-mean) ]
  ]

  create-workers N-workers [
    assign-worker-profile
    set beta (ifelse-value use-WEI?
      [ clip-01 (random-normal WEI-value 0.05) ] [ 0 ])
    set employed? false   set my-firm nobody   set effective-hours 0
  ]
  set available-workers workers
  set available-capital sum [a-K * expected-sales] of firms
  reset-ticks
end

;;--------------------------------------------------------------------
;; COUNTERFACTUAL SETUP
;;--------------------------------------------------------------------
;; Identical to setup but overrides A-param and/or WEI-value after
;; loading from CSV. Pass -1 to keep the CSV value unchanged.

to setup-counterfactual [override-A override-WEI]
  let saved-country country-select
  let saved-italy?  use-italy?
  clear-all
  set country-select saved-country
  set use-italy?     saved-italy?
  set baseline-mode? false

  ifelse use-italy? [ load-region-data ] [ load-country-data ]
  if override-A   >= 0 [ set A-param   override-A ]
  if override-WEI >= 0 [
    set WEI-value min (list 1 (max (list 0 override-WEI)))
  ]

  set wage 1   set price-capital 1   set num-ideal-workers 100
  set available-capital 0   set GDP 0
  set price-index 0   set unemployment-rate 0   set total-inventories 0

  create-firms N-firms [
    set a-L random-positive-normal 0.55 0.05
    set a-K random-positive-normal 0.40 0.05
    assign-ideal-type
    set desired-labor 0   set desired-capital 0
    set actual-labor 0    set actual-capital 0
    set actual-output 0   set total-cost 0
    set price 0           set inventories 0
    set scaled-sales 0    set my-workers no-turtles
  ]

  let mean-aL mean [a-L] of firms
  set E-sales-base (N-workers * (1 - u-rate / 100)) / (N-firms * mean-aL)
  ask firms [
    set expected-sales random-positive-normal E-sales-base (E-sales-base * 0.1)
  ]
  let sample-mean mean [expected-sales] of firms
  if sample-mean > 0 [
    ask firms [
      set expected-sales expected-sales * (E-sales-base / sample-mean)
    ]
  ]

  create-workers N-workers [
    assign-worker-profile
    set beta (ifelse-value use-WEI?
      [ clip-01 (random-normal WEI-value 0.05) ] [ 0 ])
    set employed? false   set my-firm nobody   set effective-hours 0
  ]
  set available-workers workers
  set available-capital sum [a-K * expected-sales] of firms
  reset-ticks
end

;;--------------------------------------------------------------------
;; STABILITY ANALYSIS
;;--------------------------------------------------------------------
;; Tracks cumulative mean and std of productivity over max-runs
;; replications to determine the minimum number of Monte Carlo runs.
;; Output: stability_prof_NW4300_NF700_<scenario>.csv

to stability-analysis-prof [max-runs]
  let filename (word "stability_prof_NW4300_NF700_" scenario ".csv")
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "run,cumulative_mean_productivity,cumulative_std_productivity"
  file-close

  let productivity-list []
  let run-counter 1

  while [run-counter <= max-runs] [
    setup-benchmark-prof
    go
    let real-GDP ifelse-value (price-index > 0) [GDP / price-index] [0]
    let n-employed count workers with [employed?]
    let prod ifelse-value (n-employed > 0)
      [real-GDP / (n-employed * 8)] [0]

    set productivity-list lput prod productivity-list
    let cum-mean mean productivity-list
    let cum-std  ifelse-value (length productivity-list > 1)
      [standard-deviation productivity-list] [0]

    file-open filename
    file-print (word run-counter ","
      precision cum-mean 6 "," precision cum-std 6)
    file-close
    set run-counter run-counter + 1
  ]
  print (word "Stability analysis complete: " max-runs " replications.")
end

;;--------------------------------------------------------------------
;; EXPERIMENT 1: THEORETICAL SCENARIOS
;;--------------------------------------------------------------------
;; Replicates Table 5. Compares macroeconomic outcomes across seven
;; scenarios. Deviations in prices (P_hat) and real GDP (g_hat) are
;; computed relative to the no-mismatch baseline.
;; Output: table5_results.csv

to run-experiment
  let filename "table5_results.csv"
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "scenario_label,nominal_GDP,price_index,P_hat_pct,real_GDP,g_hat_pct"
  file-close

  ;; Each entry: [scenario-label, scenario, use-WEI?, baseline-mode?]
  let configs (list
    (list "baseline"                "uniform"      true  true )
    (list "uniform_no_culture"      "uniform"      false false)
    (list "uniform"                 "uniform"      true  false)
    (list "concentrated_no_culture" "concentrated" false false)
    (list "concentrated"            "concentrated" true  false)
    (list "random_no_culture"       "random"       false false)
    (list "random"                  "random"       true  false)
  )

  let n-runs 100
  let baseline-p    0
  let baseline-real 0

  foreach configs [ cfg ->
    let scenario-label item 0 cfg
    set scenario        item 1 cfg
    set use-WEI?        item 2 cfg
    set baseline-mode?  item 3 cfg

    let sum-gdp 0   let sum-p 0   let sum-real 0

    repeat n-runs [
      setup-benchmark-prof
      go
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      set sum-gdp  sum-gdp  + GDP
      set sum-p    sum-p    + price-index
      set sum-real sum-real + real-gdp
    ]

    let avg-gdp  sum-gdp  / n-runs
    let avg-p    sum-p    / n-runs
    let avg-real sum-real / n-runs

    if scenario-label = "baseline" [
      set baseline-p    avg-p
      set baseline-real avg-real
    ]

    let p-hat ifelse-value (baseline-p    > 0)
      [((avg-p    - baseline-p)    / baseline-p)    * 100] [0]
    let g-hat ifelse-value (baseline-real > 0)
      [((avg-real - baseline-real) / baseline-real) * 100] [0]

    file-open filename
    file-print (word scenario-label ","
      precision avg-gdp  2 "," precision avg-p  4 ","
      precision p-hat    2 "," precision avg-real 2 ","
      precision g-hat    2)
    file-close

    print (word "Done: " scenario-label
      "  GDP=" precision avg-gdp 2
      "  P=" precision avg-p 4
      "  P_hat=" precision p-hat 2 "%"
      "  realGDP=" precision avg-real 2
      "  g_hat=" precision g-hat 2 "%")
  ]
  print "=== EXPERIMENT 1 COMPLETE ==="
end

;;--------------------------------------------------------------------
;; EXPERIMENT 2A: CROSS-COUNTRY PRODUCTIVITY RANKING
;;--------------------------------------------------------------------
;; Replicates Table 6. Runs 100 replications per country with WEI
;; active and 100 with WEI inactive.
;; Output: table6_results.csv

to run-country-comparison
  set use-italy? false
  let filename "table6_results.csv"
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "country,productivity_with_WEI,productivity_no_WEI"
  file-close

  let countries (list
    "Austria" "Belgium" "Bulgaria" "Denmark" "Finland"
    "France" "Germany" "Greece" "Hungary" "Italy"
    "Netherlands" "Poland" "Portugal" "Slovenia" "Slovakia"
    "Spain" "Switzerland" "Turkey"
  )

  let n-runs 100

  foreach countries [ c ->
    set country-select c

    let sum-wei 0
    repeat n-runs [
      set scenario "random"
      set use-WEI? true
      set baseline-mode? false
      setup
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-wei sum-wei + (real-gdp / (n-employed * 8))
      ]
    ]

    let sum-no 0
    repeat n-runs [
      set scenario "random"
      set use-WEI? false
      set baseline-mode? false
      setup
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-no sum-no + (real-gdp / (n-employed * 8))
      ]
    ]

    file-open filename
    file-print (word c ","
      precision (sum-wei / n-runs) 3 ","
      precision (sum-no  / n-runs) 3)
    file-close
    print (word "Done: " c
      "  WEI=" precision (sum-wei / n-runs) 3
      "  noWEI=" precision (sum-no / n-runs) 3)
  ]
  print "=== COUNTRY COMPARISON COMPLETE ==="
end

;;--------------------------------------------------------------------
;; EXPERIMENT 2B: CROSS-REGION PRODUCTIVITY RANKING (ITALY)
;;--------------------------------------------------------------------
;; Same structure as run-country-comparison for 20 Italian regions.
;; Output: table_italy_results.csv

to run-region-comparison
  set use-italy? true
  let filename "table_italy_results.csv"
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "region,productivity_with_WEI,productivity_no_WEI"
  file-close

  let regions (list
    "Piemonte" "Valle d'Aosta" "Lombardia" "Trentino Alto Adige"
    "Veneto" "Friuli-Venezia Giulia" "Liguria" "Emilia-Romagna"
    "Toscana" "Umbria" "Marche" "Lazio" "Abruzzo" "Molise"
    "Campania" "Puglia" "Basilicata" "Calabria" "Sicilia" "Sardegna"
  )

  let n-runs 100

  foreach regions [ r ->
    set country-select r

    let sum-wei 0
    repeat n-runs [
      set scenario "random"
      set use-WEI? true
      set baseline-mode? false
      setup
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-wei sum-wei + (real-gdp / (n-employed * 8))
      ]
    ]

    let sum-no 0
    repeat n-runs [
      set scenario "random"
      set use-WEI? false
      set baseline-mode? false
      setup
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-no sum-no + (real-gdp / (n-employed * 8))
      ]
    ]

    file-open filename
    file-print (word r ","
      precision (sum-wei / n-runs) 3 ","
      precision (sum-no  / n-runs) 3)
    file-close
    print (word "Done: " r
      "  WEI=" precision (sum-wei / n-runs) 3
      "  noWEI=" precision (sum-no / n-runs) 3)
  ]
  print "=== REGION COMPARISON COMPLETE ==="
end

;;--------------------------------------------------------------------
;; EXPERIMENT 3A: CULTURE VS TECHNOLOGY DECOMPOSITION (EUROPE)
;;--------------------------------------------------------------------
;; Three counterfactual treatments per country:
;;   baseline:        A_i and WEI_i at observed values
;;   only-culture:    A_i replaced by sample mean
;;   only-technology: WEI_i replaced by sample mean
;; Output: decomposition_eu.csv

to run-decomposition-eu
  set use-italy? false
  set scenario "random"
  set use-WEI? true
  let means    compute-eu-means
  let mean-A   item 0 means
  let mean-WEI item 1 means

  let filename "decomposition_eu.csv"
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "country,prod_baseline,prod_only_culture,prod_only_technology"
  file-close

  let countries (list
    "Austria" "Belgium" "Bulgaria" "Denmark" "Finland"
    "France" "Germany" "Greece" "Hungary" "Italy"
    "Netherlands" "Poland" "Portugal" "Slovenia" "Slovakia"
    "Spain" "Switzerland" "Turkey"
  )

  let n-runs 100

  foreach countries [ c ->
    set country-select c
    print (word "Processing: " c)

    let sum-base 0
    let sum-cult 0
    let sum-tech 0

    repeat n-runs [
      setup-counterfactual -1 -1
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-base sum-base + (real-gdp / (n-employed * 8))
      ]
    ]

    repeat n-runs [
      setup-counterfactual mean-A -1
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-cult sum-cult + (real-gdp / (n-employed * 8))
      ]
    ]

    repeat n-runs [
      setup-counterfactual -1 mean-WEI
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [
        set sum-tech sum-tech + (real-gdp / (n-employed * 8))
      ]
    ]

    file-open filename
    file-print (word c ","
      precision (sum-base / n-runs) 4 ","
      precision (sum-cult / n-runs) 4 ","
      precision (sum-tech / n-runs) 4)
    file-close
    print (word "  baseline=" precision (sum-base / n-runs) 4
      "  only_culture=" precision (sum-cult / n-runs) 4
      "  only_tech=" precision (sum-tech / n-runs) 4)
  ]
  print "=== DECOMPOSITION EU COMPLETE ==="
end

