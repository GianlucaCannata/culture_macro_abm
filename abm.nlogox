end

;;--------------------------------------------------------------------
;; EXPERIMENT 4A: WEI TARGETING (EUROPE)
;;--------------------------------------------------------------------
;; Simulates productivity gains from incrementing WEI by +0.1, +0.2,
;; +0.3 above the observed value. A_i held fixed.
;; Output: wei_targeting_eu.csv

to run-wei-targeting-eu
  set use-italy? false
  set scenario "random"
  set use-WEI? true

  let filename "wei_targeting_eu.csv"
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "country,WEI_real,prod_baseline,prod_wei_plus01,prod_wei_plus02,prod_wei_plus03"
  file-close

  let countries (list
    "Austria" "Belgium" "Bulgaria" "Denmark" "Finland"
    "France" "Germany" "Greece" "Hungary" "Italy"
    "Netherlands" "Poland" "Portugal" "Slovenia" "Slovakia"
    "Spain" "Switzerland" "Turkey"
  )

  let n-runs 100

  foreach countries [ c ->
    set country-select c
    print (word "Processing: " c)
    load-country-data
    let real-WEI WEI-value

    let sum-b  0
    let sum-p1 0
    let sum-p2 0
    let sum-p3 0

    repeat n-runs [
      setup-counterfactual -1 -1
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-b sum-b + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.1)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p1 sum-p1 + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.2)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p2 sum-p2 + (real-gdp / (n-employed * 8)) ]
    ]

    repeat n-runs [
      setup-counterfactual -1 (real-WEI + 0.3)
      go
      let n-employed count workers with [employed?]
      let real-gdp ifelse-value (price-index > 0) [GDP / price-index] [0]
      if n-employed > 0 [ set sum-p3 sum-p3 + (real-gdp / (n-employed * 8)) ]
    ]

    file-open filename
    file-print (word c "," precision real-WEI 4 ","
      precision (sum-b  / n-runs) 4 ","
      precision (sum-p1 / n-runs) 4 ","
      precision (sum-p2 / n-runs) 4 ","
      precision (sum-p3 / n-runs) 4)
    file-close
    print (word "  WEI=" precision real-WEI 3
      "  base=" precision (sum-b / n-runs) 4
      "  +0.1=" precision (sum-p1 / n-runs) 4
      "  +0.2=" precision (sum-p2 / n-runs) 4
      "  +0.3=" precision (sum-p3 / n-runs) 4)
  ]
  print "=== WEI TARGETING EU COMPLETE ==="
end

;;--------------------------------------------------------------------
;; EXPERIMENT 4B: WEI TARGETING (ITALY)
;;--------------------------------------------------------------------
;; Same structure as run-wei-targeting-eu for 20 Italian regions.
;; Output: wei_targeting_it.csv

to run-wei-targeting-it
  set use-italy? true
  set scenario "random"
  set use-WEI? true

  let filename "wei_targeting_it.csv"
  if file-exists? filename [ file-delete filename ]
